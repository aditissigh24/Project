# OpenAI
OPENAI_API_KEY=sk-...

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=document_intelligence

# Model selection (optional overrides)
HEAVY_MODEL=gpt-4o
LIGHT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# LLM concurrency
LLM_SEMAPHORE=8

# Token budgets
MAX_CONTEXT_TOKENS=120000
MAX_SEGMENT_TOKENS=8000
MAX_SECTION_AGGREGATE_TOKENS=20000
MAX_CHAPTER_AGGREGATE_TOKENS=30000
MAX_DOCUMENT_AGGREGATE_TOKENS=40000
MAX_QUERY_CONTEXT_TOKENS=20000
MAX_CLEAN_REPAIR_TOKENS=2000

# OCR
OCR_DPI=300
OCR_MIN_ALPHA_RATIO=0.4
OCR_MIN_CHAR_COUNT=50
